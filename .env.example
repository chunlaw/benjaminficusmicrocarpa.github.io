# Copy to .env and fill in your credentials:
#   cp .env.example .env
#
# After changing GitHub or Cloudflare image settings, sync into the map page:
#   python map/~python/sync_wkcd_config.py

# Cloudflare Images API (for upload/export scripts)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Use template "Edit Cloudflare Images" or custom token with:
#   Account -> Cloudflare Images -> Read
#   Account -> Cloudflare Images -> Edit
# Scope to your account. Paste the full token (shown once only).
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# WKCD map page — pinned GitHub commit for ~webp fallback URLs
GITHUB_OWNER=benjaminficusmicrocarpa
GITHUB_REPO=benjaminficusmicrocarpa.github.io
GITHUB_COMMIT=your_full_commit_sha_here

# WKCD map page — Cloudflare image delivery (optional overrides)
CLOUDFLARE_IMAGE_DELIVERY_HASH=w8B9Irt4MxIF11C23YczhQ
CLOUDFLARE_IMAGE_VARIANT_THUMBNAIL=H300
CLOUDFLARE_IMAGE_VARIANT_FULL=public
